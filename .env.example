# Скопируйте файл в .env и подставьте реальные значения.
# В Windows: copy .env.example .env

BOT_TOKEN=123456789012345678901234567890:abcdefghijklmnopqrst

# Порядок источников ответа на свободный вопрос:
# llm_first — сначала RAG + локальная LLM (Ollama), при неудаче — FAQ из docs/faq_questions.json
# faq_first — сначала FAQ, потом Local AI
ANSWER_PRIORITY=llm_first

LOCAL_LLM_ENABLED=true
LOCAL_LLM_API_URL=http://127.0.0.1:11434/api/generate
LOCAL_LLM_MODEL=qwen2.5:7b-instruct
# Опционально: каскад моделей (primary -> fallback) через запятую
# LOCAL_LLM_MODELS=qwen2.5:7b-instruct,qwen2.5:3b,llama3.1:8b
# Опционально: роутинг по сложности вопроса
# LOCAL_LLM_SIMPLE_MODELS=qwen2.5:3b,qwen2.5:7b-instruct
# LOCAL_LLM_COMPLEX_MODELS=qwen2.5:14b,qwen2.5:7b-instruct
# LOCAL_LLM_COMPLEX_MIN_TOKENS=10
# Адаптивный режим под пиковую нагрузку:
# LOCAL_LLM_ADAPTIVE_LOAD_ENABLED=true
# LOCAL_LLM_HIGH_LOAD_WAITERS_THRESHOLD=3
# LOCAL_LLM_HIGH_LOAD_INFLIGHT_THRESHOLD=4
# LOCAL_LLM_HIGH_LOAD_MAX_TOKENS=280
# LOCAL_LLM_HIGH_LOAD_CONTEXT_FACTOR=0.7
# Сколько релевантных фрагментов брать из docs для LLM (чем больше, тем богаче контекст, но выше latency)
# LOCAL_AI_RETRIEVAL_TOP_K=12
# Лимит суммарного контекста для LLM в символах
# LOCAL_AI_LLM_MAX_CONTEXT_CHARS=4000

# При коротком RAG по теме (общежития, МФЦ, …) всё равно дернуть LLM с осторожным промптом
# LOCAL_LLM_TRY_ON_SPARSE_CONTEXT=true
# LOCAL_LLM_SPARSE_MIN_SCORE=0.14

# Опционально: короткий запрос при старте, чтобы убрать cold start первого ответа
# LOCAL_LLM_WARMUP_ENABLED=true
# LOCAL_LLM_WARMUP_TIMEOUT=12
